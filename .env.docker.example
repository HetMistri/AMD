# Copy this file to .env.docker and adjust values before deployment.

# Django runtime settings
DEBUG=False
SECRET_KEY=change-me-with-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend build-time API URLs (baked into static bundles)
VITE_API_URL=http://localhost:8000/api/v1
VITE_ADMIN_API_URL=http://localhost:8000/api/v1
VITE_ADMIN_CONSOLE_API_URL=http://localhost:8000/api/v1
